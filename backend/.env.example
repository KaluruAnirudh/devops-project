PORT=4000
NODE_ENV=development
FRONTEND_URL=http://localhost:5173
PUBLIC_API_URL=http://localhost:4000
JWT_SECRET=replace-with-a-long-random-secret
ENCRYPTION_KEY=replace-with-a-long-random-secret
GITHUB_CLIENT_ID=your-github-oauth-client-id
GITHUB_CLIENT_SECRET=your-github-oauth-client-secret
GITHUB_OAUTH_SCOPES=repo,read:user,user:email,admin:repo_hook
GITHUB_USERNAME=your-github-username
GITHUB_PAT=your-github-personal-access-token
WEBHOOK_SECRET=replace-with-a-webhook-secret
JENKINS_URL=http://localhost:8080
JENKINS_USER=admin
JENKINS_API_TOKEN=replace-with-jenkins-api-token
JENKINS_JOB_NAME=repo-cicd-engine
REGISTRY_USERNAME=your-container-registry-username
REGISTRY_PASSWORD=your-container-registry-password-or-token
DOCKER_REGISTRY=ghcr.io
K8S_NAMESPACE=devops-platform
AUTO_COMMIT_BOT_NAME=devops-bot
AUTO_COMMIT_BOT_EMAIL=devops-bot@example.com
